// BetaBet — soccer-match betting for private groups.
// See plan: split auth identity (User) from participant (Member); rounds bundle
// 1..N matches and are scored by points-per-match.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7).
}

// ─────────────────────────── Enums ───────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
  POSTPONED
}

enum Outcome {
  HOME
  DRAW
  AWAY
}

enum RoundStatus {
  DRAFT
  OPEN
  LOCKED
  SETTLED
}

// How correct picks are rewarded within a round.
//   FLAT         — every correct pick earns the match's `points`.
//   UNIQUE_BONUS — a lone correct pick earns `uniqueHitPoints`; if two or more
//                  members are correct, they each earn the shared `points`.
enum ScoringMode {
  FLAT
  UNIQUE_BONUS
}

enum TemplateKind {
  LEAGUE
  TOURNAMENT
}

// ──────────────────── Auth.js (Google + Credentials) ────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // credentials login; null for OAuth-only users
  accounts      Account[]
  sessions      Session[]
  memberships   Member[] // one Member per group
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────── Domain ────────────────────────────

model Group {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  description        String?
  defaultMatchPoints Int          @default(1) // group-wide shared/correct award default
  // Group-wide defaults for the unique-hit bonus; copied onto new rounds/matches.
  defaultScoringMode     ScoringMode @default(FLAT)
  defaultUniqueHitPoints Int         @default(2)
  members            Member[]
  invitations        Invitation[]
  rounds             Round[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Member {
  id          String       @id @default(cuid())
  groupId     String
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String? // null = guest (link-only)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String // display name, always present
  role        MemberRole   @default(MEMBER)
  accessToken String       @unique // guest link token (app-generated)
  predictions Prediction[]
  invitation  Invitation? // the single-use code this member was created from
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // An auth user joins a group once; multiple null-userId guests are allowed
  // (Postgres treats NULLs as distinct).
  @@unique([groupId, userId])
  @@index([userId])
}

model Invitation {
  id                 String     @id @default(cuid())
  groupId            String
  group              Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  code               String     @unique // app-generated, URL-safe
  label              String? // e.g. "for Carlos"
  role               MemberRole @default(MEMBER) // role granted on redemption
  expiresAt          DateTime?
  redeemedByMemberId String?    @unique // set on single-use redemption
  redeemedByMember   Member?    @relation(fields: [redeemedByMemberId], references: [id], onDelete: SetNull)
  redeemedAt         DateTime?
  createdById        String?
  createdAt          DateTime   @default(now())
}

model Team {
  id          String   @id @default(cuid())
  name        String
  shortName   String?
  crestUrl    String?
  provider    String? // API-ready (e.g. "football-data")
  externalId  String?
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  createdAt   DateTime @default(now())

  @@unique([provider, externalId])
}

model Match {
  id              String          @id @default(cuid())
  homeTeamId      String
  homeTeam        Team            @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId      String
  awayTeam        Team            @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff         DateTime
  status          MatchStatus     @default(SCHEDULED)
  homeScore       Int?
  awayScore       Int?
  result          Outcome? // derived & stored when FINISHED
  competition     String? // free-text league name
  provider        String?
  externalId      String?
  roundMatches    RoundMatch[]
  templateMatches TemplateMatch[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([provider, externalId])
  @@index([kickoff])
}

model Round {
  id           String       @id @default(cuid())
  groupId      String
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  templateId   String? // provenance: set when instantiated from a Template
  template     Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  status       RoundStatus  @default(DRAFT)
  scoringMode  ScoringMode  @default(FLAT) // how correct picks are rewarded
  lockAt       DateTime? // prediction deadline (often earliest kickoff)
  roundMatches RoundMatch[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([groupId, status])
  @@index([templateId])
}

model RoundMatch {
  id          String       @id @default(cuid())
  roundId     String
  round       Round        @relation(fields: [roundId], references: [id], onDelete: Cascade)
  matchId     String
  match       Match        @relation(fields: [matchId], references: [id], onDelete: Restrict)
  points          Int          @default(1) // shared/correct award; overrides group default
  uniqueHitPoints Int          @default(2) // award for a lone correct pick (UNIQUE_BONUS rounds)
  position        Int? // display order
  predictions Prediction[]

  @@unique([roundId, matchId])
  @@index([matchId])
}

model Prediction {
  id            String     @id @default(cuid())
  roundMatchId  String
  roundMatch    RoundMatch @relation(fields: [roundMatchId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  outcome       Outcome // 1X2 pick (required in v1)
  homeScore     Int? // score-ready (exact-score bonus later)
  awayScore     Int?
  pointsAwarded Int? // computed at settlement; null until SETTLED
  isCorrect     Boolean? // computed at settlement
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([roundMatchId, memberId]) // one prediction per member per match
  @@index([memberId])
}

// ──────────────────── Reusable competition templates ────────────────────

model Template {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  kind        TemplateKind    @default(TOURNAMENT)
  season      String? // e.g. "2026"
  provider    String? // API-ready, e.g. "fifa-wc-2026"
  externalId  String?
  matches     TemplateMatch[]
  rounds      Round[] // rounds instantiated from this template
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([provider, externalId])
}

model TemplateMatch {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  stage      String? // e.g. "Group Stage"
  groupName  String? // e.g. "Group A"
  matchday   Int? // 1..3 for the group stage
  position   Int // ordering within the template
  points     Int      @default(1) // default weight when instantiated

  @@unique([templateId, matchId])
  @@index([templateId, groupName])
  @@index([matchId])
}
